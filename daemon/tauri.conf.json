{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-json-schema/main/schema.json",
  "productName": "AlienTalk",
  "version": "0.1.0",
  "identifier": "com.alientalk.daemon",
  "build": {
    "frontendDist": "ui",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {}
}
